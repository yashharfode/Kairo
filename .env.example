# KAIRO Environment Variables Example Template
# Duplicate this file as .env.local and populate with your credentials.

# Lemma Platform Configurations
VITE_LEMMA_API_URL=
VITE_LEMMA_AUTH_URL=
VITE_LEMMA_POD_ID=

# Firebase Project Credentials
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Local Development Configs (Optional)
# LEMMA_DEV_PROXY_TARGET=https://api.lemma.work
# VITE_LEMMA_DEV_TOKEN_CMD=lemma auth print-token
